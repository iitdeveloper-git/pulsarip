# ---------------------------------------------------------------------------
# PulsarIP — environment configuration
# Copy this file to .env.local (development) or configure these as real
# environment variables in your hosting/CI platform for production.
# Never commit an actual .env / .env.local file.
# ---------------------------------------------------------------------------

# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://pulsarip.com
NEXT_PUBLIC_COMPANY_NAME=PulsarIP

# --- Contact details -----------------------------------------------------------
NEXT_PUBLIC_PHONE=+91 XXXXX XXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=+91 XXXXX XXXXX
NEXT_PUBLIC_CONTACT_EMAIL=hello@pulsarip.com
NEXT_PUBLIC_OFFICE_ADDRESS=322, Janata Colony, K.B.H., Jodhpur, Rajasthan
NEXT_PUBLIC_BUSINESS_HOURS=Mon–Sat: 10:00 AM – 7:00 PM | Sun: By Appointment

# --- Founder / Team ----------------------------------------------------------
NEXT_PUBLIC_FOUNDER_NAME=Advocate Lucky Singh

# --- Consultation types (set to true/false to feature-gate) ------------------
NEXT_PUBLIC_CONSULTATION_INPERSON=true
NEXT_PUBLIC_CONSULTATION_ONLINE=true
NEXT_PUBLIC_CONSULTATION_ONLINE_PLATFORMS=Google Meet, Zoom
NEXT_PUBLIC_CONSULTATION_PHONE=true

# --- Practice locations (comma-separated list) --------------------------------
NEXT_PUBLIC_PRACTICE_LOCATIONS=Rajasthan High Court Jodhpur, District & Sessions Courts, Consumer Commissions, Tribunals & Authorities, PAN India Advisory & Corporate Legal Services

# --- Social links ------------------------------------------------------------
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_YOUTUBE_URL=

# --- Contact form recipient/backend ------------------------------------------
CONTACT_FORM_RECIPIENT=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PulsarIP

# Optional alternative delivery: generic webhook / CRM endpoint
CONTACT_FORM_WEBHOOK_URL=

# --- Anti-spam ----------------------------------------------------------------
# Leave both blank to disable reCAPTCHA (honeypot + rate limiting still apply).
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- Analytics & monitoring (all optional, feature-gated) --------------------
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

