# ---------------------------------------------------------------------------
# PulsarIP — environment configuration
# Copy this file to .env.local (development) or configure these as real
# environment variables in your hosting/CI platform for production.
# Never commit an actual .env / .env.local file.
# ---------------------------------------------------------------------------

# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://pulsarip.com
NEXT_PUBLIC_COMPANY_NAME=PulsarIP

# --- Contact details (leave blank until confirmed by client) ---------------
NEXT_PUBLIC_PHONE=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_OFFICE_ADDRESS=
NEXT_PUBLIC_BUSINESS_HOURS=

# --- Social links ------------------------------------------------------------
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_YOUTUBE_URL=

# --- Contact form recipient/backend ------------------------------------------
CONTACT_FORM_RECIPIENT=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PulsarIP

# Optional alternative delivery: generic webhook / CRM endpoint
CONTACT_FORM_WEBHOOK_URL=

# --- Anti-spam ----------------------------------------------------------------
# Leave both blank to disable reCAPTCHA (honeypot + rate limiting still apply).
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- Analytics & monitoring (all optional, feature-gated) --------------------
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-57L7RXBD
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

