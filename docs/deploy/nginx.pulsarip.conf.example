# Example Nginx reverse-proxy configuration for pulsarip.com
# Copy to /etc/nginx/sites-available/pulsarip.com, adjust paths/certs, then:
#   sudo ln -s /etc/nginx/sites-available/pulsarip.com /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

upstream pulsarip_app {
  server 127.0.0.1:3000;
  keepalive 64;
}

# Redirect HTTP -> HTTPS
server {
  listen 80;
  listen [::]:80;
  server_name pulsarip.com www.pulsarip.com;

  # Required for Let's Encrypt HTTP-01 challenge renewal
  location /.well-known/acme-challenge/ {
    root /var/www/certbot;
  }

  location / {
    return 301 https://pulsarip.com$request_uri;
  }
}

# Redirect non-canonical host (www) to canonical host (apex)
server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name www.pulsarip.com;

  ssl_certificate     /etc/letsencrypt/live/pulsarip.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/pulsarip.com/privkey.pem;

  return 301 https://pulsarip.com$request_uri;
}

server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name pulsarip.com;

  ssl_certificate     /etc/letsencrypt/live/pulsarip.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/pulsarip.com/privkey.pem;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_prefer_server_ciphers off;

  # HSTS is also set by the app (next.config.ts); setting it here too is
  # harmless and keeps it enforced even if a request bypasses the app.
  add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;

  gzip on;
  gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript image/svg+xml;
  gzip_min_length 1024;

  client_max_body_size 2m;

  location / {
    proxy_pass http://pulsarip_app;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_cache_bypass $http_upgrade;
  }

  location /api/health {
    proxy_pass http://pulsarip_app;
    access_log off;
  }

  # Long-cache immutable Next.js build assets
  location /_next/static/ {
    proxy_pass http://pulsarip_app;
    proxy_cache_valid 200 365d;
    add_header Cache-Control "public, max-age=31536000, immutable";
  }
}
